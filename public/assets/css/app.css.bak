:root{--bg:#0b1220;--card:#101a33;--text:#e6edf7;--muted:#9fb0d0;--accent:#4ade80;--line:rgba(255,255,255,.08)}*{box-sizing:border-box}body{margin:0;font-family:system-ui,-apple-system,Segoe UI,Roboto,Arial,sans-serif;background:radial-gradient(1200px 600px at 20% 10%,rgba(74,222,128,.18),transparent 55%),radial-gradient(1000px 600px at 90% 20%,rgba(59,130,246,.18),transparent 55%),var(--bg);color:var(--text)}a{color:inherit;text-decoration:none}a:hover{opacity:.9}.shell{max-width:1100px;margin:0 auto;padding:24px}.topbar{display:flex;align-items:center;justify-content:space-between;gap:16px;padding:14px 16px;background:rgba(16,26,51,.6);backdrop-filter:blur(10px);border:1px solid var(--line);border-radius:14px}.brand{font-weight:700;letter-spacing:.4px}.nav{display:flex;gap:14px;align-items:center;color:var(--muted)}.hero{margin-top:32px;padding:28px;border:1px solid var(--line);border-radius:18px;background:linear-gradient(180deg,rgba(16,26,51,.75),rgba(16,26,51,.35))}.hero h1{margin:0 0 10px;font-size:36px;line-height:1.1}.hero p{margin:0 0 18px;color:var(--muted);max-width:60ch}.cta{display:flex;gap:12px;flex-wrap:wrap}.btn{display:inline-flex;align-items:center;justify-content:center;padding:10px 14px;border-radius:12px;background:var(--accent);color:#06210f;font-weight:700;border:none;cursor:pointer}.btn-ghost{background:transparent;border:1px solid var(--line);color:var(--text)}.form{display:grid;gap:12px;max-width:520px}.form label{display:grid;gap:6px;color:var(--muted)}input,select{padding:10px 12px;border-radius:12px;border:1px solid var(--line);background:rgba(0,0,0,.18);color:var(--text);outline:none}input:focus,select:focus{border-color:rgba(74,222,128,.45)}.err{color:#fecaca;font-size:13px}.filters{display:grid;grid-template-columns:1.2fr .9fr .9fr .7fr .7fr .9fr auto;gap:10px;align-items:end;margin:14px 0 18px}.grid{display:grid;grid-template-columns:repeat(3,minmax(0,1fr));gap:12px}.card{padding:14px;border-radius:16px;border:1px solid var(--line);background:rgba(16,26,51,.35)}.card-title{font-weight:800;margin-bottom:6px}.card-meta{color:var(--muted);font-size:13px;margin-top:6px}.card-price{margin-top:10px;font-size:18px;font-weight:800}.empty{padding:16px;border:1px dashed var(--line);border-radius:16px;color:var(--muted);grid-column:1/-1}.detail{display:grid;gap:10px;margin-top:14px}.detail-row{display:flex;gap:12px;align-items:baseline;justify-content:space-between;border-bottom:1px solid var(--line);padding:10px 0}.detail-row strong{color:var(--muted)}.footer{padding:28px 0;color:var(--muted)}.footer a{color:var(--text)}.footer .shell{padding-top:0}.muted{color:var(--muted)}.kpi{display:grid;grid-template-columns:repeat(3,minmax(0,1fr));gap:12px;margin-top:18px}.kpi .card{padding:18px}.kpi .num{font-size:28px;font-weight:900}.kpi .label{color:var(--muted);margin-top:4px}.section{margin-top:26px}.badge{display:inline-flex;gap:8px;align-items:center;padding:6px 10px;border:1px solid var(--line);border-radius:999px;color:var(--muted);font-size:12px}.auth{max-width:520px;margin:0 auto}.flash{padding:10px 12px;border-radius:12px;border:1px solid rgba(74,222,128,.35);background:rgba(74,222,128,.12);color:var(--text);margin:12px 0}.alert{padding:10px 12px;border-radius:12px;border:1px solid rgba(251,146,60,.35);background:rgba(251,146,60,.12);color:var(--text);margin:12px 0}.logo{height:28px;width:auto}table{width:100%;border-collapse:collapse}th,td{padding:10px 8px;border-bottom:1px solid var(--line);text-align:left}th{color:var(--muted);font-weight:700}.panel{padding:16px;border:1px solid var(--line);border-radius:16px;background:linear-gradient(180deg,rgba(16,26,51,.75),rgba(16,26,51,.35))}@media(max-width:960px){.filters{grid-template-columns:1fr 1fr;align-items:stretch}.grid{grid-template-columns:repeat(2,minmax(0,1fr))}}@media(max-width:640px){.grid{grid-template-columns:1fr}.topbar{flex-direction:column;align-items:flex-start}}.site{min-height:100vh}.header-area .top-header-area{border-bottom:1px solid var(--line);background:rgba(16,26,51,.35)}.top-header-content{display:flex;gap:16px;justify-content:space-between;align-items:center;flex-wrap:wrap}.top-header-meta p{margin:0;color:var(--muted);font-weight:600}.top-header-meta-right{display:flex;gap:12px;flex-wrap:wrap;justify-content:flex-end}.top-link{color:var(--muted)}.nav-area{padding:14px 0}.breadcrumb-area{padding:24px 0 6px}.breadcrumb-text h1{margin:0 0 6px;font-size:34px;line-height:1.15}.breadcrumb-text p{margin:0;color:var(--muted);font-weight:600}.section{padding:36px 0}.section-gray{background:rgba(255,255,255,.03);border-top:1px solid var(--line);border-bottom:1px solid var(--line)}.section-title{margin:0 0 14px;font-size:22px}.section-heading{margin-bottom:16px}.section-heading h2{margin:0;font-size:26px}.section-heading h2 span{color:var(--accent)}.section-spacer{margin-top:18px}.feature-grid{display:grid;grid-template-columns:repeat(3,minmax(0,1fr));gap:12px}.feature-card{padding:16px;border-radius:16px;border:1px solid var(--line);background:rgba(16,26,51,.45)}.feature-card h3{margin:0 0 10px;font-size:14px;letter-spacing:.4px}.feature-card p{margin:0;color:var(--muted);line-height:1.45}.list{margin:10px 0 0;padding-left:18px;color:var(--muted)}.list li{margin:6px 0}.table-wrap{overflow:auto;border:1px solid var(--line);border-radius:16px;background:rgba(16,26,51,.35)}.table{width:100%;border-collapse:collapse;min-width:700px}.table th,.table td{padding:12px 12px;border-bottom:1px solid var(--line);text-align:left;vertical-align:top}.table thead th{color:var(--muted);font-weight:700}.right{text-align:right;margin-top:14px}.footer-area{padding:36px 0;border-top:1px solid var(--line);background:rgba(16,26,51,.25)}.footer-grid{display:grid;grid-template-columns:repeat(3,minmax(0,1fr));gap:18px}.footer-col h3{margin:0 0 10px;font-size:14px;letter-spacing:.4px}.footer-col h4{margin:14px 0 10px;font-size:13px;color:var(--muted)}.footer-col p{margin:0 0 10px;color:var(--muted);line-height:1.45}.footer-links{display:grid;gap:8px;color:var(--muted)}.copywrite{margin-top:22px;padding-top:16px;border-top:1px solid var(--line);color:var(--muted);text-align:center}@media (max-width: 980px){.feature-grid{grid-template-columns:1fr}.footer-grid{grid-template-columns:1fr}}@media (max-width: 560px){.breadcrumb-text h1{font-size:28px}}
