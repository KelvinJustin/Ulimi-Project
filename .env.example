# Application Environment
APP_ENV=local
APP_BASE_URL=http://localhost

# Database Configuration
DB_HOST=127.0.0.1
DB_NAME=ulimi
DB_USER=root
DB_PASS=

# Marketplace Database (Optional)
MARKETPLACE_DB_NAME=ulimi_marketplace

# Security Keys
# Generate random secrets for production using: openssl rand -base64 32
CSRF_KEY=generate-random-csrf-key-here
JWT_SECRET=generate-random-jwt-secret-here

# Cookie Security
# Set to '1' in production to enable secure cookies
COOKIE_SECURE=0

# Stripe Configuration (Optional)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
